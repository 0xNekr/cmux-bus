#!/usr/bin/env bash
# agent-cancel [--scope repo|workspace] [--bus-dir DIR] <id> [--force] [reason]
# Close a thread by appending a 'block' event to=user with the given reason.
# Refuses to cancel a thread already done or blocked, unless --force is given.

set -euo pipefail

AGENT_CMD="agent-cancel"
script_path="${BASH_SOURCE[0]}"
while [ -L "$script_path" ]; do
    script_dir="$(cd "$(dirname "$script_path")" && pwd)"
    link_target="$(readlink "$script_path")"
    case "$link_target" in
        /*) script_path="$link_target";;
        *)  script_path="$script_dir/$link_target";;
    esac
done
. "$(cd "$(dirname "$script_path")" && pwd)/agent-lib"

usage() {
    cat >&2 <<EOF
usage: agent-cancel [--scope repo|workspace] [--bus-dir DIR] <id> [--force] [reason]
  id       any event id in the thread (resolves to thread root automatically)
  reason   free text (default: "cancelled")
  --force  allow cancelling a thread already done/blocked

prints the new event id on stdout
EOF
    agent_bus_common_usage >&2
    exit 2
}

agent_bus_parse_common "$@"
if [ "${#AGENT_BUS_REMAINING_ARGS[@]}" -gt 0 ]; then
    set -- "${AGENT_BUS_REMAINING_ARGS[@]}"
else
    set --
fi

[ $# -ge 1 ] || usage
id="$1"; shift

force=0
reason=""
while [ $# -gt 0 ]; do
    case "$1" in
        --force) force=1; shift;;
        --)      shift; reason="$*"; break;;
        --*)     echo "agent-cancel: unknown flag '$1'" >&2; exit 1;;
        *)       reason="$*"; break;;
    esac
done

[ -z "$reason" ] && reason="cancelled"

agent_bus_set_paths
agent_bus_need_existing

root=$(jq -Rrs --arg id "$id" '
    def root($m;$e): if $e.ref==null then $e.id else root($m;$m[$e.ref]) end;
    split("\n") | map(fromjson?) | map(select(type=="object" and .id)) as $events |
    ($events | map({key:.id,value:.}) | from_entries) as $m |
    if $m[$id] == null then "" else root($m;$m[$id]) end
' "$AGENT_BUS_FILE")

[ -n "$root" ] || {
    echo "agent-cancel: event id '$id' not found in bus" >&2
    exit 1
}

last_status=$(jq -Rrs --arg root "$root" '
    def thread_root($m;$e): if $e.ref==null then $e.id else thread_root($m;$m[$e.ref]) end;
    split("\n") | map(fromjson?) | map(select(type=="object" and .id)) as $events |
    ($events | map({key:.id,value:.}) | from_entries) as $m |
    $events | map(select(thread_root($m;.) == $root)) | last | .status
' "$AGENT_BUS_FILE")

if [ "$last_status" = "done" ] || [ "$last_status" = "blocked" ]; then
    if [ $force -ne 1 ]; then
        echo "agent-cancel: thread $root is already $last_status (use --force to override)" >&2
        exit 1
    fi
fi

agent_bus_export_env
agent-send user block --ref "$root" "cancelled: $reason"
