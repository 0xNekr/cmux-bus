#!/usr/bin/env bash
set -euo pipefail
json=0; stale_filter=all; stuck_filter=all; stuck_after="${AGENT_BUS_STUCK_AFTER_MIN:-10}"
while [ $# -gt 0 ]; do
  case "$1" in
    --json) json=1;;
    --no-stale) [ "$stale_filter" = all ] || { echo "agent-inbox: use only one stale filter" >&2; exit 2; }; stale_filter=no;;
    --only-stale) [ "$stale_filter" = all ] || { echo "agent-inbox: use only one stale filter" >&2; exit 2; }; stale_filter=only;;
    --no-stuck) [ "$stuck_filter" = all ] || { echo "agent-inbox: use only one stuck filter" >&2; exit 2; }; stuck_filter=no;;
    --only-stuck) [ "$stuck_filter" = all ] || { echo "agent-inbox: use only one stuck filter" >&2; exit 2; }; stuck_filter=only;;
    --stuck-after) [ $# -ge 2 ] || { echo "agent-inbox: --stuck-after needs minutes" >&2; exit 2; }; stuck_after="$2"; shift;;
    *) echo "usage: agent-inbox [--json] [--no-stale|--only-stale] [--no-stuck|--only-stuck] [--stuck-after MIN]" >&2; exit 2;;
  esac; shift
done
case "$stuck_after" in ''|*[!0-9-]*) echo "agent-inbox: stuck threshold must be an integer" >&2; exit 2;; esac
[ -f .agents/agents.json ] || { echo "agent-inbox: no .agents/ here — run 'agent-init <your_name>' first" >&2; exit 1; }
[ -f .agents/bus.jsonl ] || { echo "agent-inbox: no .agents/bus.jsonl — run 'agent-init <your_name>' first" >&2; exit 1; }
my_surface="${CMUX_SURFACE_ID:-}"; [ -n "$my_surface" ] || { echo "agent-inbox: CMUX_SURFACE_ID not set" >&2; exit 1; }
me=$(jq -r --arg s "$my_surface" '.agents|to_entries[]|select(.value==$s)|.key' .agents/agents.json | head -n1)
[ -n "$me" ] || { echo "agent-inbox: this surface is not registered — run 'agent-init <your_name>' first" >&2; exit 1; }
agents=$(jq -c '.agents' .agents/agents.json); now=$(date -u +%s)
items=$(jq -s --arg me "$me" --argjson agents "$agents" --arg stale_filter "$stale_filter" --arg stuck_filter "$stuck_filter" --argjson now "$now" --argjson stuck_after "$stuck_after" '
  def root($m;$e): if $e.ref==null then $e.id else root($m;$m[$e.ref]) end;
  def epoch($ts): ($ts|strptime("%Y-%m-%dT%H:%M:%SZ")|mktime);
  map(select(type=="object" and .id)) as $events |
  ($events|map({key:.id,value:.})|from_entries) as $m |
  ($events|map(.+{root:root($m;.)})|group_by(.root)|map({root:.[0].root,last:.[-1]})) |
  map(select(.last.to==$me and (.last.status|IN("done","blocked")|not)) |
    .+{stale:($agents[.last.from] == null), age_minutes:(([0, (($now - epoch(.last.ts)) / 60 | floor)] | max))} |
    .+{stuck:(($stuck_after > 0) and (.last.status=="in_progress") and (.age_minutes >= $stuck_after))}) |
  if $stale_filter=="no" then map(select(.stale|not)) elif $stale_filter=="only" then map(select(.stale)) else . end |
  if $stuck_filter=="no" then map(select(.stuck|not)) elif $stuck_filter=="only" then map(select(.stuck)) else . end
' .agents/bus.jsonl)
[ "$json" -eq 1 ] && { printf '%s\n' "$items"; exit 0; }
count=$(printf '%s' "$items" | jq 'length')
[ "$count" -eq 0 ] && { echo "agent-inbox: no open threads for $me"; exit 0; }
printf '%-28s %-8s %-12s %-10s %-10s %s\n' ROOT ID TYPE STATUS FROM BODY
printf '%s' "$items" | jq -r '.[]|[((if .stale then "[stale] " else "" end)+(if .stuck then "[stuck "+(.age_minutes|tostring)+"m] " else "" end)+.root),.last.id,.last.type,.last.status,.last.from,(.last.body|gsub("[\r\n]+";" "))]|@tsv' |
while IFS=$'\t' read -r root id type status from body; do
  printf '%-28s %-8s %-12s %-10s %-10s %s\n' "$root" "$id" "$type" "$status" "$from" "$body"
done
