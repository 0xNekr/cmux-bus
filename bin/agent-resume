#!/usr/bin/env bash
# agent-resume [--scope repo|workspace] [--bus-dir DIR] <id> [--force] [body]
# Re-handoff a thread to its original recipient (the 'to' of the root event).
# Useful when the peer crashed mid-task: the thread chain stays intact, a new
# handoff event becomes the latest state, and the peer's inbox sees it again.
# Refuses if the thread is already done or blocked, unless --force is given.

set -euo pipefail

AGENT_CMD="agent-resume"
script_path="${BASH_SOURCE[0]}"
while [ -L "$script_path" ]; do
    script_dir="$(cd "$(dirname "$script_path")" && pwd)"
    link_target="$(readlink "$script_path")"
    case "$link_target" in
        /*) script_path="$link_target";;
        *)  script_path="$script_dir/$link_target";;
    esac
done
. "$(cd "$(dirname "$script_path")" && pwd)/agent-lib"

usage() {
    cat >&2 <<EOF
usage: agent-resume [--scope repo|workspace] [--bus-dir DIR] <id> [--force] [body]
  id       any event id in the thread (resolves to thread root automatically)
  body     new handoff body (default: "RESUME: <previous root body>")
  --force  allow resuming a thread already done/blocked

prints the new event id on stdout
EOF
    agent_bus_common_usage >&2
    exit 2
}

agent_bus_parse_common "$@"
if [ "${#AGENT_BUS_REMAINING_ARGS[@]}" -gt 0 ]; then
    set -- "${AGENT_BUS_REMAINING_ARGS[@]}"
else
    set --
fi

[ $# -ge 1 ] || usage
id="$1"; shift

force=0
body=""
while [ $# -gt 0 ]; do
    case "$1" in
        --force) force=1; shift;;
        --)      shift; body="$*"; break;;
        --*)     echo "agent-resume: unknown flag '$1'" >&2; exit 1;;
        *)       body="$*"; break;;
    esac
done

agent_bus_set_paths
agent_bus_need_existing

root=$(jq -Rrs --arg id "$id" '
    def root($m;$e): if $e.ref==null then $e.id else root($m;$m[$e.ref]) end;
    split("\n") | map(fromjson?) | map(select(type=="object" and .id)) as $events |
    ($events | map({key:.id,value:.}) | from_entries) as $m |
    if $m[$id] == null then "" else root($m;$m[$id]) end
' "$AGENT_BUS_FILE")

[ -n "$root" ] || {
    echo "agent-resume: event id '$id' not found in bus" >&2
    exit 1
}

root_event=$(jq -Rcs --arg root "$root" '
    split("\n") | map(fromjson?) | map(select(type=="object" and .id == $root)) | .[0]
' "$AGENT_BUS_FILE")

orig_recipient=$(echo "$root_event" | jq -r '.to')
prev_body=$(echo "$root_event" | jq -r '.body')

if [ -z "$orig_recipient" ] || [ "$orig_recipient" = "null" ]; then
    echo "agent-resume: cannot determine original recipient for thread $root" >&2
    exit 1
fi

if [ "$orig_recipient" = "user" ]; then
    echo "agent-resume: the original recipient was 'user' — nothing to wake up" >&2
    echo "agent-resume: send a regular agent-send to a peer instead" >&2
    exit 1
fi

last_status=$(jq -Rrs --arg root "$root" '
    def thread_root($m;$e): if $e.ref==null then $e.id else thread_root($m;$m[$e.ref]) end;
    split("\n") | map(fromjson?) | map(select(type=="object" and .id)) as $events |
    ($events | map({key:.id,value:.}) | from_entries) as $m |
    $events | map(select(thread_root($m;.) == $root)) | last | .status
' "$AGENT_BUS_FILE")

if [ "$last_status" = "done" ] || [ "$last_status" = "blocked" ]; then
    if [ $force -ne 1 ]; then
        echo "agent-resume: thread $root is already $last_status (use --force to override)" >&2
        exit 1
    fi
fi

if [ -z "$body" ]; then
    body="RESUME: $prev_body"
fi

agent_bus_export_env
agent-send "$orig_recipient" handoff --ref "$root" "$body"
