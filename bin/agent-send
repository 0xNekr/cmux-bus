#!/usr/bin/env bash
# agent-send [--scope repo|workspace] [--bus-dir DIR] <to> <type> [--ref ID] [--paths "p1,p2"] [--status STATUS] <body...>
# Append event(s) to the resolved bus and signal recipient(s) via cmux send.

set -euo pipefail

AGENT_CMD="agent-send"
script_path="${BASH_SOURCE[0]}"
while [ -L "$script_path" ]; do
    script_dir="$(cd "$(dirname "$script_path")" && pwd)"
    link_target="$(readlink "$script_path")"
    case "$link_target" in
        /*) script_path="$link_target";;
        *)  script_path="$script_dir/$link_target";;
    esac
done
. "$(cd "$(dirname "$script_path")" && pwd)/agent-lib"

usage() {
    cat >&2 <<EOF
usage: agent-send [--scope repo|workspace] [--bus-dir DIR] <to> <type> [flags] <body...>
  to       recipient agent name, comma-separated names, 'all', or 'user'
  type     ask | handoff | done | block | ack
  --ref ID         parent event id (chains the thread)
  --paths "p1,p2"  comma-separated paths_claimed
  --status STATUS  open | in_progress | done | blocked (default: type-derived)

prints new event id(s) on stdout, one per line
EOF
    agent_bus_common_usage >&2
    exit 2
}

agent_bus_parse_common "$@"
if [ "${#AGENT_BUS_REMAINING_ARGS[@]}" -gt 0 ]; then
    set -- "${AGENT_BUS_REMAINING_ARGS[@]}"
else
    set --
fi

[ $# -ge 3 ] || usage

to="$1"; shift
type="$1"; shift
broadcast_requested=0
[ "$to" = "all" ] && broadcast_requested=1
case "$to" in *,*) broadcast_requested=1;; esac

case "$type" in
    ask|handoff|done|block|ack) ;;
    *) echo "agent-send: invalid type '$type' (ask|handoff|done|block|ack)" >&2; exit 1;;
esac

if [ "$broadcast_requested" -eq 1 ] && [ "$type" != "ask" ]; then
    echo "agent-send: broadcast is only supported for type 'ask'" >&2
    exit 1
fi

ref=""
paths_csv=""
status=""

while [ $# -gt 0 ]; do
    case "$1" in
        --ref)    ref="$2"; shift 2;;
        --paths)  paths_csv="$2"; shift 2;;
        --status) status="$2"; shift 2;;
        --)       shift; break;;
        --*)      echo "agent-send: unknown flag '$1'" >&2; exit 1;;
        *)        break;;
    esac
done

[ $# -ge 1 ] || { echo "agent-send: missing body" >&2; exit 1; }
body="$*"

if [ -z "$status" ]; then
    case "$type" in
        ask|handoff) status="open";;
        ack)         status="in_progress";;
        done)        status="done";;
        block)       status="blocked";;
    esac
fi
case "$status" in open|in_progress|done|blocked) ;; *)
    echo "agent-send: invalid status '$status'" >&2; exit 1;;
esac

agent_bus_set_paths
agent_bus_need_existing
agent_bus_need_agents

if [ -n "$ref" ]; then
    jq -Rer --arg ref "$ref" '
        fromjson?
        | select(type == "object" and .id == $ref)
        | true
    ' "$AGENT_BUS_FILE" >/dev/null || {
        echo "agent-send: unknown --ref '$ref' — cannot append an orphan event" >&2
        exit 1
    }
fi

my_surface="${CMUX_SURFACE_ID:-}"
[ -n "$my_surface" ] || { echo "agent-send: CMUX_SURFACE_ID not set" >&2; exit 1; }

from=$(jq -r --arg s "$my_surface" '.agents | to_entries[] | select(.value == $s) | .key' "$AGENT_BUS_AGENTS_FILE" | head -n1)
[ -n "$from" ] || {
    echo "agent-send: this surface is not registered — run 'agent-init <your_name>' first" >&2
    exit 1
}

if [ "$to" = "all" ]; then
    recipients=$(jq -r --arg from "$from" '.agents | keys[] | select(. != $from)' "$AGENT_BUS_AGENTS_FILE")
elif [ "$to" = "user" ]; then
    recipients="user"
else
    recipients=$(jq -nr --arg csv "$to" --arg from "$from" '
        $csv
        | split(",")
        | map(gsub("^\\s+|\\s+$"; ""))
        | map(select(length > 0 and . != $from))
        | reduce .[] as $r ([]; if index($r) then . else . + [$r] end)
        | .[]
    ')
fi

[ -n "$recipients" ] || {
    echo "agent-send: no recipients after expanding '$to'" >&2
    exit 1
}

if [ "$(printf '%s\n' "$recipients" | wc -l | tr -d ' ')" -gt 1 ] && [ -n "$ref" ]; then
    echo "agent-send: broadcast with --ref is not supported; reply to each thread separately" >&2
    exit 1
fi

live=""
if ! { [ "$recipients" = "user" ]; }; then
    # A surface is alive if it still appears in surface-health (closed panes
    # disappear). Do NOT require in_window=true: that flag only marks the
    # currently selected workspace, so an alive peer in a backgrounded
    # workspace would look stale and weaken this check whenever the user is
    # looking elsewhere. surface-health defaults to $CMUX_WORKSPACE_ID.
    live=$(cmux --id-format both surface-health 2>/dev/null | awk '/type=terminal/ {print $2}')
fi

while IFS= read -r recipient; do
    [ -n "$recipient" ] || continue
    [ "$recipient" != "user" ] || continue
    target_surface=$(jq -r --arg n "$recipient" '.agents[$n] // empty' "$AGENT_BUS_AGENTS_FILE")
    [ -n "$target_surface" ] || {
        echo "agent-send: unknown recipient '$recipient' in bus $AGENT_BUS_DIR_EFFECTIVE — known agents:" >&2
        jq -r '.agents | keys[]' "$AGENT_BUS_AGENTS_FILE" | sed 's/^/  /' >&2
        echo "agent-send: ask them to run 'agent-init $recipient' in their current pane" >&2
        echo "agent-send: do not use 'cmux send' as a fallback; use '--scope repo' only if you intentionally want the folder-local bus" >&2
        exit 1
    }
    if [ -n "$live" ] && ! printf '%s\n' "$live" | grep -qxF "$target_surface"; then
        echo "agent-send: recipient '$recipient' has a stale surface (pane closed or cmux restarted)" >&2
        echo "agent-send: ask them to run 'agent-init $recipient' from their current pane" >&2
        echo "agent-send: do not use 'cmux send' as a fallback" >&2
        exit 1
    fi
done <<EOF
$recipients
EOF

paths_json='[]'
if [ -n "$paths_csv" ]; then
    paths_json=$(jq -nc --arg csv "$paths_csv" '$csv | split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(length > 0))')
fi

ref_json='null'
[ -n "$ref" ] && ref_json=$(jq -nc --arg r "$ref" '$r')

while IFS= read -r recipient; do
    [ -n "$recipient" ] || continue
    id=$(od -An -N4 -tx1 /dev/urandom | tr -d ' \n')
    ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    event=$(jq -nc \
        --arg id "$id" \
        --arg ts "$ts" \
        --arg from "$from" \
        --arg to "$recipient" \
        --arg type "$type" \
        --arg cwd "$PWD" \
        --argjson ref "$ref_json" \
        --arg status "$status" \
        --argjson paths_claimed "$paths_json" \
        --arg body "$body" \
        '{id:$id, ts:$ts, from:$from, to:$to, type:$type, ref:$ref, status:$status, paths_claimed:$paths_claimed, cwd:$cwd, body:$body}')

    agent_bus_append_event "$event"

    if [ "$recipient" != "user" ]; then
        target_surface=$(jq -r --arg n "$recipient" '.agents[$n] // empty' "$AGENT_BUS_AGENTS_FILE")
        cmux send --surface "$target_surface" "new $type id=$id from=$from" >/dev/null
        cmux send-key --surface "$target_surface" Enter >/dev/null
    fi

    echo "$id"
done <<EOF
$recipients
EOF
