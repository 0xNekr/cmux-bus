#!/usr/bin/env bash
# agent-thread [--scope repo|workspace] [--bus-dir DIR] [--json] <id>
# Show the full event history for a thread.

set -euo pipefail

AGENT_CMD="agent-thread"
script_path="${BASH_SOURCE[0]}"
while [ -L "$script_path" ]; do
    script_dir="$(cd "$(dirname "$script_path")" && pwd)"
    link_target="$(readlink "$script_path")"
    case "$link_target" in
        /*) script_path="$link_target";;
        *)  script_path="$script_dir/$link_target";;
    esac
done
. "$(cd "$(dirname "$script_path")" && pwd)/agent-lib"

usage() {
    echo "usage: agent-thread [--scope repo|workspace] [--bus-dir DIR] [--json] <id>" >&2
    agent_bus_common_usage >&2
    exit 2
}

json=0
agent_bus_parse_common "$@"
if [ "${#AGENT_BUS_REMAINING_ARGS[@]}" -gt 0 ]; then
    set -- "${AGENT_BUS_REMAINING_ARGS[@]}"
else
    set --
fi

while [ $# -gt 0 ]; do
    case "$1" in
        --json) json=1; shift;;
        --*) echo "agent-thread: unknown flag '$1'" >&2; exit 2;;
        *) break;;
    esac
done

[ $# -eq 1 ] || usage
id="$1"

agent_bus_set_paths
agent_bus_need_existing

thread=$(jq -Rsr --arg id "$id" '
    def root($m;$e): if $e.ref==null then $e.id else root($m;$m[$e.ref]) end;
    split("\n") | map(fromjson?) |
    map(select(type=="object" and .id)) as $events |
    ($events | map({key:.id,value:.}) | from_entries) as $m |
    if $m[$id] == null then
        null
    else
        root($m;$m[$id]) as $root |
        $events
        | map(. + {root: root($m;.)})
        | map(select(.root == $root))
    end
' "$AGENT_BUS_FILE")

[ "$thread" != null ] || {
    echo "agent-thread: unknown event id '$id'" >&2
    exit 1
}

if [ "$json" -eq 1 ]; then
    printf '%s\n' "$thread"
    exit 0
fi

root=$(printf '%s' "$thread" | jq -r '.[0].root')
count=$(printf '%s' "$thread" | jq 'length')
last_status=$(printf '%s' "$thread" | jq -r '.[-1].status')

echo "thread: $root"
echo "events: $count"
echo "status: $last_status"
printf '%-20s %-8s %-12s %-10s %-10s %-10s %s\n' TS ID TYPE STATUS FROM TO BODY
printf '%s' "$thread" | jq -r '
    .[]
    | [
        .ts,
        .id,
        .type,
        .status,
        .from,
        .to,
        (.body | gsub("[\r\n]+";" "))
      ]
    | @tsv
' | while IFS=$'\t' read -r ts event_id type status from to body; do
    printf '%-20s %-8s %-12s %-10s %-10s %-10s %s\n' "$ts" "$event_id" "$type" "$status" "$from" "$to" "$body"
done
