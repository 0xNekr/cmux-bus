#!/usr/bin/env bash
# agent-wait [--scope repo|workspace] [--bus-dir DIR] [--timeout SEC] [--interval SEC] [--status done|blocked|final] <id>
# Wait until a thread reaches a target status.

set -euo pipefail

AGENT_CMD="agent-wait"
script_path="${BASH_SOURCE[0]}"
while [ -L "$script_path" ]; do
    script_dir="$(cd "$(dirname "$script_path")" && pwd)"
    link_target="$(readlink "$script_path")"
    case "$link_target" in
        /*) script_path="$link_target";;
        *)  script_path="$script_dir/$link_target";;
    esac
done
. "$(cd "$(dirname "$script_path")" && pwd)/agent-lib"

usage() {
    echo "usage: agent-wait [--scope repo|workspace] [--bus-dir DIR] [--timeout SEC] [--interval SEC] [--status done|blocked|final] <id>" >&2
    agent_bus_common_usage >&2
    exit 2
}

timeout=600
interval=1
target_status=final

agent_bus_parse_common "$@"
if [ "${#AGENT_BUS_REMAINING_ARGS[@]}" -gt 0 ]; then
    set -- "${AGENT_BUS_REMAINING_ARGS[@]}"
else
    set --
fi

while [ $# -gt 0 ]; do
    case "$1" in
        --timeout)
            [ $# -ge 2 ] || usage
            timeout="$2"
            shift 2
            ;;
        --interval)
            [ $# -ge 2 ] || usage
            interval="$2"
            shift 2
            ;;
        --status)
            [ $# -ge 2 ] || usage
            target_status="$2"
            shift 2
            ;;
        --*) echo "agent-wait: unknown flag '$1'" >&2; exit 2;;
        *) break;;
    esac
done

[ $# -eq 1 ] || usage
id="$1"

case "$timeout" in ''|*[!0-9]*) echo "agent-wait: --timeout must be a non-negative integer" >&2; exit 2;; esac
case "$interval" in ''|*[!0-9.]*) echo "agent-wait: --interval must be a positive number" >&2; exit 2;; esac
if ! jq -en --arg interval "$interval" '($interval | tonumber) > 0' >/dev/null 2>&1; then
    echo "agent-wait: --interval must be a positive number" >&2
    exit 2
fi
case "$target_status" in
    done|blocked|final) ;;
    *) echo "agent-wait: --status must be done, blocked, or final" >&2; exit 2;;
esac

agent_bus_set_paths
agent_bus_need_existing

thread_last() {
    jq -Rsr --arg id "$id" '
        def root($m;$e): if $e.ref==null then $e.id else root($m;$m[$e.ref]) end;
        split("\n") | map(fromjson?) |
        map(select(type=="object" and .id)) as $events |
        ($events | map({key:.id,value:.}) | from_entries) as $m |
        if $m[$id] == null then
            null
        else
            root($m;$m[$id]) as $root |
            $events
            | map(. + {root: root($m;.)})
            | map(select(.root == $root))
            | last
        end
    ' "$AGENT_BUS_FILE"
}

matches_target() {
    local status="$1"
    case "$target_status" in
        final) [ "$status" = done ] || [ "$status" = blocked ];;
        *) [ "$status" = "$target_status" ];;
    esac
}

deadline=$(( $(date +%s) + timeout ))
while :; do
    last="$(thread_last)"
    [ "$last" != null ] || {
        echo "agent-wait: unknown event id '$id'" >&2
        exit 1
    }
    status="$(printf '%s' "$last" | jq -r .status)"
    if matches_target "$status"; then
        printf '%s\n' "$last"
        exit 0
    fi
    if [ "$(date +%s)" -ge "$deadline" ]; then
        echo "agent-wait: timed out waiting for '$id' to reach $target_status (last status: $status)" >&2
        exit 1
    fi
    sleep "$interval"
done
