#!/usr/bin/env bash
# agent-watch [--scope repo|workspace] [--bus-dir DIR] [--once] [--me] [--full] [--no-color] [--clear] [--lines N] [--interval SEC]
# Watch bus events as they are appended.

set -euo pipefail

AGENT_CMD="agent-watch"
script_path="${BASH_SOURCE[0]}"
while [ -L "$script_path" ]; do
    script_dir="$(cd "$(dirname "$script_path")" && pwd)"
    link_target="$(readlink "$script_path")"
    case "$link_target" in
        /*) script_path="$link_target";;
        *)  script_path="$script_dir/$link_target";;
    esac
done
. "$(cd "$(dirname "$script_path")" && pwd)/agent-lib"

usage() {
    echo "usage: agent-watch [--scope repo|workspace] [--bus-dir DIR] [--once] [--me] [--full] [--no-color] [--clear] [--lines N] [--interval SEC]" >&2
    agent_bus_common_usage >&2
    exit 2
}

clear_bus() {
    local tries=0

    trap 'rmdir "$AGENT_BUS_LOCK" 2>/dev/null || true' EXIT INT TERM
    while ! mkdir "$AGENT_BUS_LOCK" 2>/dev/null; do
        tries=$((tries + 1))
        if [ "$tries" -ge 100 ]; then
            echo "agent-watch: timed out waiting for bus lock ($AGENT_BUS_LOCK)" >&2
            exit 1
        fi
        sleep 0.1
    done

    : > "$AGENT_BUS_FILE"
    rmdir "$AGENT_BUS_LOCK"
    trap - EXIT INT TERM
}

once=0
me_only=0
full=0
no_color=0
clear=0
lines=20
interval=1

agent_bus_parse_common "$@"
if [ "${#AGENT_BUS_REMAINING_ARGS[@]}" -gt 0 ]; then
    set -- "${AGENT_BUS_REMAINING_ARGS[@]}"
else
    set --
fi

while [ $# -gt 0 ]; do
    case "$1" in
        --once) once=1; shift;;
        --me) me_only=1; shift;;
        --full) full=1; shift;;
        --no-color) no_color=1; shift;;
        --clear) clear=1; shift;;
        --lines)
            [ $# -ge 2 ] || usage
            lines="$2"
            shift 2
            ;;
        --interval)
            [ $# -ge 2 ] || usage
            interval="$2"
            shift 2
            ;;
        --*) echo "agent-watch: unknown flag '$1'" >&2; exit 2;;
        *) usage;;
    esac
done

case "$lines" in ''|*[!0-9]*) echo "agent-watch: --lines must be a non-negative integer" >&2; exit 2;; esac
case "$interval" in ''|*[!0-9.]*) echo "agent-watch: --interval must be a positive number" >&2; exit 2;; esac
if ! jq -en --arg interval "$interval" '($interval | tonumber) > 0' >/dev/null 2>&1; then
    echo "agent-watch: --interval must be a positive number" >&2
    exit 2
fi

agent_bus_set_paths
agent_bus_need_existing

if [ "$clear" -eq 1 ]; then
    clear_bus
fi

me=""
if [ "$me_only" -eq 1 ]; then
    agent_bus_need_agents
    my_surface="${CMUX_SURFACE_ID:-}"
    [ -n "$my_surface" ] || {
        echo "agent-watch: CMUX_SURFACE_ID not set" >&2
        exit 1
    }
    me=$(jq -r --arg s "$my_surface" '.agents|to_entries[]|select(.value==$s)|.key' "$AGENT_BUS_AGENTS_FILE" | head -n1)
    [ -n "$me" ] || {
        echo "agent-watch: this surface is not registered — run 'agent-init <your_name>' first" >&2
        exit 1
    }
fi

color_enabled=0
if [ -t 1 ] && [ "$no_color" -eq 0 ]; then
    color_enabled=1
fi

term_cols=100
if [ -t 1 ] && command -v tput >/dev/null 2>&1; then
    term_cols=$(tput cols 2>/dev/null || printf '100')
fi
case "$term_cols" in ''|*[!0-9]*) term_cols=100;; esac
body_limit=$((term_cols - 4))
[ "$body_limit" -lt 40 ] && body_limit=40
[ "$body_limit" -gt 160 ] && body_limit=160

c_reset=$'\033[0m'
c_dim=$'\033[2m'
c_bold=$'\033[1m'
c_blue=$'\033[34m'
c_cyan=$'\033[36m'
c_green=$'\033[32m'
c_yellow=$'\033[33m'
c_red=$'\033[31m'
c_magenta=$'\033[35m'

color_for_status() {
    case "$1" in
        open) printf '%s' "$c_blue";;
        in_progress) printf '%s' "$c_yellow";;
        done) printf '%s' "$c_green";;
        blocked) printf '%s' "$c_red";;
        *) printf '%s' "$c_reset";;
    esac
}

color_for_type() {
    case "$1" in
        ask) printf '%s' "$c_cyan";;
        handoff) printf '%s' "$c_magenta";;
        ack) printf '%s' "$c_yellow";;
        done) printf '%s' "$c_green";;
        block) printf '%s' "$c_red";;
        *) printf '%s' "$c_reset";;
    esac
}

print_header() {
    [ "$color_enabled" -eq 1 ] || return 0
    if [ "$once" -eq 1 ]; then
        printf '%bagent-watch snapshot%b\n' "$c_dim" "$c_reset"
    else
        printf '%bagent-watch live  Ctrl-C to stop%b\n' "$c_dim" "$c_reset"
    fi
}

print_events() {
    jq -Rr --arg me "$me" --argjson full "$full" --argjson body_limit "$body_limit" '
        fromjson?
        |
        select(type=="object" and .id)
        | select(($me == "") or (.from == $me) or (.to == $me))
        | (.body | gsub("[\r\n]+";" ")) as $body
        | (if $full == 1 or ($body | length) <= $body_limit then $body else (($body[0:($body_limit - 3)]) + "...") end) as $summary
        | [
            (.ts | sub("^[0-9]{4}-[0-9]{2}-[0-9]{2}T";"") | sub("Z$";"")),
            .id,
            .type,
            .status,
            (.from + "->" + .to),
            $summary
          ]
        | @tsv
    ' | while IFS=$'\t' read -r ts id type status route body; do
        if [ "$color_enabled" -eq 1 ]; then
            type_color="$(color_for_type "$type")"
            status_color="$(color_for_status "$status")"
            [ "${printed_event:-0}" -eq 0 ] || printf '\n'
            printed_event=1
            printf '%b%s%b  %b%s%b  %b%s%b/%b%s%b  %b%s%b\n' \
                "$c_dim" "$ts" "$c_reset" \
                "$c_bold" "$route" "$c_reset" \
                "$type_color" "$type" "$c_reset" \
                "$status_color" "$status" "$c_reset" \
                "$c_dim" "$id" "$c_reset"
            printf '  %s\n' "$body"
        else
            printf '%8s  %-22s  %-5s/%-11s  %-8s  %s\n' "$ts" "$route" "$type" "$status" "$id" "$body"
        fi
    done
}

print_header

if [ "$once" -eq 1 ]; then
    if [ "$lines" -eq 0 ]; then
        cat "$AGENT_BUS_FILE" | print_events
    else
        tail -n "$lines" "$AGENT_BUS_FILE" | print_events
    fi
    exit 0
fi

tail -n "$lines" "$AGENT_BUS_FILE" | print_events
seen_lines=$(wc -l < "$AGENT_BUS_FILE" | tr -d ' ')
while :; do
    sleep "$interval"
    current_lines=$(wc -l < "$AGENT_BUS_FILE" | tr -d ' ')
    if [ "$current_lines" -gt "$seen_lines" ]; then
        tail -n $((current_lines - seen_lines)) "$AGENT_BUS_FILE" | print_events
        seen_lines="$current_lines"
    elif [ "$current_lines" -lt "$seen_lines" ]; then
        seen_lines="$current_lines"
    fi
done
