#!/usr/bin/env bash
# agent-watch [--once] [--me] [--full] [--no-color] [--lines N] [--interval SEC]
# Watch bus events as they are appended.

set -euo pipefail

usage() {
    echo "usage: agent-watch [--once] [--me] [--full] [--no-color] [--lines N] [--interval SEC]" >&2
    exit 2
}

once=0
me_only=0
full=0
no_color=0
lines=20
interval=1

while [ $# -gt 0 ]; do
    case "$1" in
        --once) once=1; shift;;
        --me) me_only=1; shift;;
        --full) full=1; shift;;
        --no-color) no_color=1; shift;;
        --lines)
            [ $# -ge 2 ] || usage
            lines="$2"
            shift 2
            ;;
        --interval)
            [ $# -ge 2 ] || usage
            interval="$2"
            shift 2
            ;;
        --*) echo "agent-watch: unknown flag '$1'" >&2; exit 2;;
        *) usage;;
    esac
done

case "$lines" in ''|*[!0-9]*) echo "agent-watch: --lines must be a non-negative integer" >&2; exit 2;; esac
case "$interval" in ''|*[!0-9.]*) echo "agent-watch: --interval must be a positive number" >&2; exit 2;; esac
if ! jq -en --arg interval "$interval" '($interval | tonumber) > 0' >/dev/null 2>&1; then
    echo "agent-watch: --interval must be a positive number" >&2
    exit 2
fi

[ -f .agents/bus.jsonl ] || {
    echo "agent-watch: no .agents/bus.jsonl — run 'agent-init <your_name>' first" >&2
    exit 1
}

me=""
if [ "$me_only" -eq 1 ]; then
    [ -f .agents/agents.json ] || {
        echo "agent-watch: no .agents/agents.json — run 'agent-init <your_name>' first" >&2
        exit 1
    }
    my_surface="${CMUX_SURFACE_ID:-}"
    [ -n "$my_surface" ] || {
        echo "agent-watch: CMUX_SURFACE_ID not set" >&2
        exit 1
    }
    me=$(jq -r --arg s "$my_surface" '.agents|to_entries[]|select(.value==$s)|.key' .agents/agents.json | head -n1)
    [ -n "$me" ] || {
        echo "agent-watch: this surface is not registered — run 'agent-init <your_name>' first" >&2
        exit 1
    }
fi

color_enabled=0
if [ -t 1 ] && [ "$no_color" -eq 0 ]; then
    color_enabled=1
fi

c_reset=$'\033[0m'
c_dim=$'\033[2m'
c_bold=$'\033[1m'
c_blue=$'\033[34m'
c_cyan=$'\033[36m'
c_green=$'\033[32m'
c_yellow=$'\033[33m'
c_red=$'\033[31m'
c_magenta=$'\033[35m'

color_for_status() {
    case "$1" in
        open) printf '%s' "$c_blue";;
        in_progress) printf '%s' "$c_yellow";;
        done) printf '%s' "$c_green";;
        blocked) printf '%s' "$c_red";;
        *) printf '%s' "$c_reset";;
    esac
}

color_for_type() {
    case "$1" in
        ask) printf '%s' "$c_cyan";;
        handoff) printf '%s' "$c_magenta";;
        ack) printf '%s' "$c_yellow";;
        done) printf '%s' "$c_green";;
        block) printf '%s' "$c_red";;
        *) printf '%s' "$c_reset";;
    esac
}

print_header() {
    [ "$color_enabled" -eq 1 ] || return 0
    printf '%b%8s  %-22s  %-18s  %-8s  %s%b\n' "$c_dim" TIME ROUTE EVENT ID MESSAGE "$c_reset"
    printf '%b%8s  %-22s  %-18s  %-8s  %s%b\n' "$c_dim" "--------" "----------------------" "------------------" "--------" "----------------" "$c_reset"
}

print_events() {
    jq -Rr --arg me "$me" --argjson full "$full" '
        fromjson?
        |
        select(type=="object" and .id)
        | select(($me == "") or (.from == $me) or (.to == $me))
        | (.body | gsub("[\r\n]+";" ")) as $body
        | (if $full == 1 or ($body | length) <= 120 then $body else (($body[0:117]) + "...") end) as $summary
        | [
            (.ts | sub("^[0-9]{4}-[0-9]{2}-[0-9]{2}T";"") | sub("Z$";"")),
            .id,
            .type,
            .status,
            (.from + "->" + .to),
            $summary
          ]
        | @tsv
    ' | while IFS=$'\t' read -r ts id type status route body; do
        if [ "$color_enabled" -eq 1 ]; then
            type_color="$(color_for_type "$type")"
            status_color="$(color_for_status "$status")"
            printf '%b%8s%b  %b%-22s%b  %b%-5s%b/%b%-11s%b  %b%-8s%b  %s\n' \
                "$c_dim" "$ts" "$c_reset" \
                "$c_bold" "$route" "$c_reset" \
                "$type_color" "$type" "$c_reset" \
                "$status_color" "$status" "$c_reset" \
                "$c_dim" "$id" "$c_reset" \
                "$body"
        else
            printf '%8s  %-22s  %-5s/%-11s  %-8s  %s\n' "$ts" "$route" "$type" "$status" "$id" "$body"
        fi
    done
}

print_header

if [ "$once" -eq 1 ]; then
    if [ "$lines" -eq 0 ]; then
        cat .agents/bus.jsonl | print_events
    else
        tail -n "$lines" .agents/bus.jsonl | print_events
    fi
    exit 0
fi

tail -n "$lines" .agents/bus.jsonl | print_events
seen_lines=$(wc -l < .agents/bus.jsonl | tr -d ' ')
while :; do
    sleep "$interval"
    current_lines=$(wc -l < .agents/bus.jsonl | tr -d ' ')
    if [ "$current_lines" -gt "$seen_lines" ]; then
        tail -n $((current_lines - seen_lines)) .agents/bus.jsonl | print_events
        seen_lines="$current_lines"
    elif [ "$current_lines" -lt "$seen_lines" ]; then
        seen_lines="$current_lines"
    fi
done
